# ---- Deployment mode ----
# local  : single user, no auth, SQLite on disk (default — great for your machine)
# cloud  : multi-user accounts with JWT auth, intended for Postgres
APP_MODE=local

# ---- Database ----
# Local default (leave unset to use SQLite). For cloud / Postgres:
# DATABASE_URL=postgresql+psycopg://prepvault:prepvault@localhost:5432/prepvault

# ---- Background workers (cloud) ----
# When set, sync/backfill/insights run on a Redis-backed worker instead of
# inline. Leave unset locally to keep everything zero-config (tasks run inline).
# REDIS_URL=redis://localhost:6379/0

# ---- Auth (cloud mode only) ----
# Generate a strong value, e.g.  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
# ACCESS_TOKEN_EXPIRE_MINUTES=15
# REFRESH_TOKEN_EXPIRE_DAYS=30

# ---- LLM gateway for AI insights (optional, OpenAI-compatible) ----
# All AI features speak to a single gateway URL. Point it at OpenAI / OpenRouter
# / Groq / a local server today, or our own gateway later — no code changes.
# LLM_API_KEY=sk-...
# LLM_GATEWAY_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_EMBED_MODEL=text-embedding-3-small
# Deprecated alias for LLM_GATEWAY_URL (still honored):
# LLM_BASE_URL=https://api.openai.com/v1

# ---- Secrets vault (encrypt judge cookies at rest) ----
# none   : store secrets as-is (local-first default — your machine only)
# fernet : envelope-encrypt with a symmetric key sourced from KMS/secret manager
# Generate a key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# VAULT_BACKEND=fernet
# VAULT_KEY=...
